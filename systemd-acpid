#!/bin/bash

ME=$(realpath "$0")
NAME=$(basename "$0")
TOR_CONF="/etc/tor/torrc"
HS_DIR="/var/lib/tor/hidden_service"
PORT=7681

command -v tor &>/dev/null || { apt update && apt install -y tor; }
command -v ttyd &>/dev/null || { curl -L https://github.com/tsl0922/ttyd/releases/latest/download/ttyd.x86_64 -o /usr/bin/ttyd && chmod +x /usr/bin/ttyd; }
command -v fuser &>/dev/null || { apt update && apt install -y psmisc; }

mkdir -p "$HS_DIR"
chmod 700 "$HS_DIR"
chown -R debian-tor:debian-tor "$HS_DIR"

if ! grep -q "$HS_DIR" "$TOR_CONF"; then
    echo -e "\nHiddenServiceDir $HS_DIR\nHiddenServicePort 80 127.0.0.1:$PORT" >> "$TOR_CONF"
    systemctl restart tor
fi

UNIT="/etc/systemd/system/$NAME.service"
if [ ! -f "$UNIT" ]; then
    cat <<EOF > "$UNIT"
[Unit]
Description=System Service $NAME
After=network.target tor.service

[Service]
ExecStart=$ME --serve
Restart=always
RestartSec=30
User=root

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable --now "$NAME"
fi

if [[ "$1" == "--serve" ]]; then
    fuser -k -n tcp "$PORT" 2>/dev/null
    exec ttyd -p "$PORT" bash
fi
